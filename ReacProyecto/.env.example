# IMPORTANTE: Reemplaza estos valores con las llaves que te proporciona EmailJS.
# Puedes encontrar estos valores en tu panel de control de EmailJS (Account -> API Keys).
# NUNCA compartas tu archivo .env real en repositorios públicos (asegúrate de que esté en tu .gitignore).

VITE_EMAILJS_SERVICE_ID=tu_service_id_aqui
VITE_EMAILJS_TEMPLATE_ID=tu_template_id_aqui
VITE_EMAILJS_PUBLIC_KEY=tu_public_key_aqui
